## Registry — locked to official npm
registry=https://registry.npmjs.org/

## Security
# Prevent install scripts from running automatically (supply chain attack vector)
ignore-scripts=true
# Require exact versions in lockfile
save-exact=true
# Strict peer dependencies — fail on conflicts instead of silently resolving
strict-peer-dependencies=true
# Prevent hoisting — no phantom dependencies
hoist=false
# Verify package integrity via SHA-512
resolution-mode=highest

## Lockfile
# In CI, --frozen-lockfile is enforced via Makefile/CI, not here
