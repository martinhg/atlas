# Atlas — Environment Variables
# Copy this file to .env and fill in the values.

# PostgreSQL connection string
DATABASE_URL=postgres://atlas:atlas@localhost:5432/atlas?sslmode=disable

# Server port (default: 8080)
PORT=8080

# Frontend URL for CORS and OAuth redirects (default: http://localhost:5173)
WEB_URL=http://localhost:5173

# GitHub OAuth App credentials (required)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# JWT signing secret for access/refresh tokens (required)
JWT_SECRET=

# GitHub App credentials for repository discovery (required)
# App ID from your GitHub App settings
GITHUB_APP_ID=
# Private key PEM — raw or base64-encoded
GITHUB_APP_PRIVATE_KEY=
# Webhook secret configured in your GitHub App
GITHUB_WEBHOOK_SECRET=
